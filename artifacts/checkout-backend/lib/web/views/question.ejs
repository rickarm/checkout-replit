<div class="step-question" x-data="questionStep()" x-init="start()">
  <div class="question-progress">
    <span class="dim">Question <%= index + 1 %>/<%= total %></span>
    <span class="progress-dots">
      <% for (let i = 0; i < total; i++) { %>
        <span class="dot <%= i < index ? 'completed' : (i === index ? 'active' : '') %>">
          <%= i < index ? '●' : (i === index ? '◉' : '○') %>
        </span>
      <% } %>
    </span>
  </div>

  <div class="question-title">
    <p x-data="typewriter('<%= question.title.replace(/'/g, "\\'") %>', 40)" x-init="start()" x-ref="titleTypewriter">
      <span class="amber" x-text="displayed"></span><span class="cursor" x-show="!done">█</span>
    </p>
  </div>

  <% if (question.prompt) { %>
    <div class="question-prompt" x-show="promptVisible" x-cloak>
      <p class="dim"><%= question.prompt %></p>
    </div>
  <% } %>

  <% if (question.example) { %>
    <div class="question-example" x-show="promptVisible" x-cloak>
      <p class="dim-more"><%= question.example %></p>
    </div>
  <% } %>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="terminal-error">
      <span class="error">ERROR:</span> <%= error %>
    </div>
  <% } %>

  <form
    class="terminal-form"
    x-show="inputVisible"
    x-cloak
    hx-post="/step/question/<%= index %>"
    hx-target="#screen-content"
    hx-swap="innerHTML"
  >
    <div class="terminal-input-wrapper">
      <span class="input-prompt amber">&gt; </span>
      <% if (question.type === 'number') { %>
        <input
          type="text"
          name="answer"
          class="terminal-input"
          inputmode="numeric"
          pattern="[0-9]*"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          x-ref="answerInput"
          x-on:input="updateCursor()"
          placeholder=""
          value="<%= (previousAnswers && previousAnswers[question.id]) || '' %>"
        >
      <% } else { %>
        <input
          type="text"
          name="answer"
          class="terminal-input"
          autocomplete="off"
          autocapitalize="sentences"
          spellcheck="false"
          x-ref="answerInput"
          x-on:input="updateCursor()"
          placeholder=""
          value="<%= (previousAnswers && previousAnswers[question.id]) || '' %>"
        >
      <% } %>
      <span class="input-mirror" x-ref="inputMirror" aria-hidden="true"></span>
      <span class="input-cursor" x-ref="inputCursor">█</span>
    </div>

    <div class="form-actions">
      <button type="submit" class="terminal-btn">[Enter] Submit</button>
      <% if (!question.required) { %>
        <button type="submit" class="terminal-btn dim">[S] Skip</button>
      <% } %>
    </div>
  </form>
</div>
