<div class="page-history" x-data="{ loaded: false }" x-init="setTimeout(() => loaded = true, 100)">
  <div class="history-header">
    <p class="amber">Journal Entries</p>
    <p class="dim"><%= total %> entries</p>
  </div>

  <div class="history-separator">
    <span class="dim">──────────────────────────────────────────</span>
  </div>

  <% if (total === 0) { %>
    <div class="history-empty">
      <br>
      <p class="dim">No entries found.</p>
      <br>
      <a href="/" hx-get="/step/breathing" hx-target="#screen-content" hx-swap="innerHTML" class="terminal-btn">[N] Create First Entry</a>
    </div>
  <% } else { %>
    <div class="history-list" x-show="loaded" x-cloak>
      <% const months = ['January','February','March','April','May','June','July','August','September','October','November','December']; %>
      <% let lastYear = null; %>
      <% for (const key of Object.keys(grouped).sort().reverse()) { %>
        <% const group = grouped[key]; %>
        <% if (group.year !== lastYear) { %>
          <% lastYear = group.year; %>
          <div class="history-year">
            <br>
            <p class="amber"><%= group.year %></p>
          </div>
        <% } %>
        <div class="history-month">
          <p class="dim">&nbsp;&nbsp;<%= months[parseInt(group.month) - 1] %></p>
          <% for (const entry of group.entries) { %>
            <% const dayMatch = entry.filename.match(/^\d{4}-\d{2}-(\d{2})/); %>
            <% const day = dayMatch ? dayMatch[1] : '??'; %>
            <div class="history-entry">
              <a
                href="/history/<%= group.year %>/<%= group.month %>/<%= entry.filename %>"
                hx-get="/history/<%= group.year %>/<%= group.month %>/<%= entry.filename %>"
                hx-target="#screen-content"
                hx-swap="innerHTML"
                class="entry-link"
              >
                <span class="amber">&nbsp;&nbsp;&nbsp;&nbsp;<%= day %></span>
                <span class="dim">&nbsp;&mdash;&nbsp;<%= entry.filename %></span>
              </a>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
