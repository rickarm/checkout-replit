<div class="step-saved" x-data="savedStep()" x-init="start()">
  <div class="saved-content">
    <div x-show="phase >= 1">
      <p class="success" x-data="typewriter('Entry saved.', 50)" x-init="start()">
        <span x-text="displayed"></span><span class="cursor" x-show="!done">█</span>
      </p>
    </div>

    <div x-show="phase >= 2" x-cloak>
      <br>
      <p class="dim">Path: <%= path %></p>
    </div>

    <div x-show="phase >= 3" x-cloak>
      <br>
      <p x-data="typewriter('Done!', 80)" x-init="start()">
        <span class="amber" x-text="displayed"></span><span class="cursor" x-show="!done">█</span>
      </p>
    </div>

    <div x-show="phase >= 4" x-cloak class="saved-actions">
      <br>
      <br>
      <a href="/" hx-get="/step/breathing" hx-target="#screen-content" hx-swap="innerHTML" class="terminal-btn">[N] New Entry</a>
      <a href="/history" hx-get="/history" hx-target="#screen-content" hx-push-url="/history" class="terminal-btn">[H] View History</a>
    </div>
  </div>
</div>
