<div class="step-breathing" x-data="breathingExercise()" x-init="start()">
  <div class="breathing-content">
    <!-- Typewriter intro -->
    <div x-show="phase === 'intro'" class="typewriter-block">
      <p class="prompt-text" x-data="typewriter('Evening Checkout', 60)" x-init="start()">
        <span class="amber" x-text="displayed"></span><span class="cursor" x-show="!done">█</span>
      </p>
    </div>

    <!-- Breathing phase -->
    <div x-show="phase === 'breathe'" x-cloak class="breathing-phase">
      <p class="dim">Take a moment to breathe.</p>
      <p class="dim">4 seconds in... 4 seconds out.</p>

      <div class="breathing-visual">
        <div class="breath-circle" :class="{ 'inhale': breathIn, 'exhale': !breathIn }"></div>
        <p class="breath-label amber" x-text="breathIn ? 'Breathe in...' : 'Breathe out...'"></p>
      </div>

      <p class="countdown">
        <span class="amber" x-text="timer"></span>
      </p>
    </div>

    <!-- Ready prompt -->
    <div x-show="phase === 'ready'" x-cloak class="ready-prompt">
      <p class="dim">Take a moment to breathe.</p>
      <p class="dim">4 seconds in... 4 seconds out.</p>
      <br>
      <p x-data="typewriter('Ready?', 80)" x-init="start()">
        <span class="amber" x-text="displayed"></span><span class="cursor" x-show="!done">█</span>
      </p>
      <br>
      <button
        class="terminal-btn"
        hx-get="/step/question/0"
        hx-target="#screen-content"
        hx-swap="innerHTML"
      >[Y] Begin</button>

      <button
        class="terminal-btn dim"
        hx-get="/step/breathing"
        hx-target="#screen-content"
        hx-swap="innerHTML"
      >[R] Repeat</button>
    </div>
  </div>
</div>
