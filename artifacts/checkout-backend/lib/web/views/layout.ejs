<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
  <title>Checkout Journal</title>
  <link rel="stylesheet" href="/css/doogie.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black">
  <meta name="theme-color" content="#0000AA">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="dos-desktop">
    <div class="dos-container">
      <div class="scanlines"></div>
      <div class="screen-header">
        <span class="header-title">CHECKOUT JOURNAL v1.0</span>
        <nav class="header-nav">
          <a href="/" hx-get="/step/breathing" hx-target="#screen-content" hx-push-url="/" class="nav-link">New Entry</a>
          <span class="nav-sep">|</span>
          <a href="/history" hx-get="/history" hx-target="#screen-content" hx-push-url="/history" class="nav-link">History</a>
        </nav>
      </div>
      <div class="screen-body" id="screen-content">
        <% if (partial === 'breathing') { %>
          <%- include('breathing') %>
        <% } else if (partial === 'history') { %>
          <%- include('history', { grouped, total }) %>
        <% } else if (partial === 'entry') { %>
          <%- include('entry', { content, filename, error }) %>
        <% } %>
      </div>
    </div>
  </div>

  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <script src="https://unpkg.com/alpinejs@3.14.3/dist/cdn.min.js" defer></script>
  <script src="/js/terminal.js"></script>

  <% if (typeof registerSW === 'undefined' || registerSW !== false) { %>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
  <% } %>
</body>
</html>
