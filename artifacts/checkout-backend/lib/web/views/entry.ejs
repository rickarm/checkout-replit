<div class="page-entry" x-data="entryView()" x-init="start()">
  <div class="entry-header">
    <a
      href="/history"
      hx-get="/history"
      hx-target="#screen-content"
      hx-swap="innerHTML"
      class="terminal-btn-inline"
    >&lt; Back</a>
    <span class="dim">&nbsp;&nbsp;<%= filename %></span>
  </div>

  <div class="entry-separator">
    <span class="dim">──────────────────────────────────────────</span>
  </div>

  <% if (error) { %>
    <div class="terminal-error">
      <span class="error">ERROR:</span> <%= error %>
    </div>
  <% } else if (content) { %>
    <div class="entry-content" x-show="visible" x-cloak>
      <% const lines = content.split('\n'); %>
      <% for (const line of lines) { %>
        <% if (line.startsWith('## ')) { %>
          <p class="entry-question amber"><%= line.replace('## ', '') %></p>
        <% } else if (line.startsWith('---')) { %>
          <p class="dim">──────────────────────────────────────────</p>
        <% } else if (line.startsWith('**Metadata**')) { %>
          <p class="dim"><%= line.replace(/\*\*/g, '') %></p>
        <% } else if (line.startsWith('- ')) { %>
          <p class="dim"><%= line %></p>
        <% } else if (line.trim()) { %>
          <p class="entry-answer"><%= line %></p>
        <% } %>
      <% } %>
    </div>
  <% } %>
</div>
