<div class="step-review" x-data="reviewStep()" x-init="start()">
  <div class="review-header">
    <p x-data="typewriter('Here\\'s your entry:', 40)" x-init="start()">
      <span class="amber" x-text="displayed"></span><span class="cursor" x-show="!done">█</span>
    </p>
  </div>

  <div class="review-separator">
    <span class="dim">══════════════════════════════════════════════════</span>
  </div>

  <% if (error) { %>
    <div class="terminal-error">
      <span class="error">ERROR:</span> <%= error %>
    </div>
  <% } %>

  <div class="review-content" x-show="contentVisible" x-cloak>
    <% if (markdown) { %>
      <% const lines = markdown.split('\n'); %>
      <% for (const line of lines) { %>
        <% if (line.startsWith('## ')) { %>
          <p class="review-question amber"><%= line.replace('## ', '') %></p>
        <% } else if (line.startsWith('---')) { %>
          <p class="dim">──────────────────────────────────────────</p>
        <% } else if (line.startsWith('**Metadata**')) { %>
          <p class="dim"><%= line %></p>
        <% } else if (line.startsWith('- ')) { %>
          <p class="dim"><%= line %></p>
        <% } else if (line.trim()) { %>
          <p class="review-answer"><%= line %></p>
        <% } %>
      <% } %>
    <% } %>
  </div>

  <div class="review-separator" x-show="contentVisible" x-cloak>
    <span class="dim">══════════════════════════════════════════════════</span>
  </div>

  <div class="review-actions" x-show="actionsVisible" x-cloak>
    <p class="amber">Save this entry?</p>
    <br>
    <form hx-post="/step/save" hx-target="#screen-content" hx-swap="innerHTML" style="display:inline">
      <button type="submit" class="terminal-btn">[Y] Save</button>
    </form>
    <button class="terminal-btn dim" hx-get="/step/breathing" hx-target="#screen-content" hx-swap="innerHTML">[N] Discard</button>
  </div>
</div>
